{
  "name": "honoka-bridge",
  "version": "1.4.6",
  "description": "Local bridge server for Honoka — saves Notion docs and images to disk, opens in Cursor/VS Code",
  "bin": "index.js",
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "start": "node index.js",
    "build:win": "pkg . --targets node20-win-x64 --output bin/honoka-bridge.exe",
    "build:macos": "pkg . --targets node20-macos-x64 --output bin/honoka-bridge-macos",
    "build:linux": "pkg . --targets node20-linux-x64 --output bin/honoka-bridge-linux",
    "build:all": "npm run build:win && npm run build:macos && npm run build:linux"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "keywords": [
    "notion",
    "honoka",
    "bridge",
    "cursor"
  ],
  "license": "MIT",
  "author": "",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.15.2",
    "jsdom": "^29.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "playwright": "^1.59.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
