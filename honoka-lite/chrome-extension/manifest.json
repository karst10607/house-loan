{
  "manifest_version": 3,
  "name": "Honoka Lite",
  "version": "1.3.4",
  "key": "",
  "description": "Detect remaining token budget per section in design docs. Reduces hallucination when feeding docs to AI.",
  "browser_specific_settings": {
    "gecko": {
      "id": "honoka-token-budget@honoka",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "history"],
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "host_permissions": [
    "https://*.notion.so/*",
    "https://*.notion.site/*",
    "https://notion.so/*",
    "http://127.0.0.1:7749/*",
    "http://127.0.0.1:44124/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.notion.so/*", "https://*.notion.site/*", "https://notion.so/*"],
      "js": ["dist/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
