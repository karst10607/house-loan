{
  "manifest_version": 3,
  "name": "Knowledge Hub Clipper",
  "version": "2.0.0",
  "description": "Visually select and clip clean content to your local Knowledge Hub.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:44123/*",
    "http://localhost:44123/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
